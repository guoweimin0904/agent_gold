# --- API Keys ---
BINANCE_API_KEY=
BINA...n
# --- LLM ---
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_...n
# --- Telegram / Notification ---
TELEGRAM_BOT_TOKEN=
TELE...n
# --- Data Layer ---
DATA_REQUEST_TIMEOUT=30
DATA_RETRY_MAX=3
DATA_RETRY_DELAY=2

# --- Execution Gate ---
ENABLE_REAL_TRADING=false
EXECUTION_MODE=paper
EXCHANGE_API_WITHDRAWAL=false
EXCHANGE_IP_WHITELIST=disabled
STOP_LOSS_REQUIRED=true
INVALID_COND_REQUIRED=true
POSITION_LIMIT_PCT=20

# --- Risk ---
MAX_POSITION_SIZE_USDT=1000
MAX_DAILY_LOSS_USDT=200
STOP_LOSS_PCT=0.05

# --- Scheduler ---
CHECK_INTERVAL_MINUTES=15
