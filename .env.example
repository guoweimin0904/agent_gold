# --- API Keys ---
BINANCE_API_KEY=
BINA...n
# --- LLM ---
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_...n
# --- Telegram / Notification ---
TELEGRAM_BOT_TOKEN=
TELE...n
# --- Data Layer ---
DATA_REQUEST_TIMEOUT=30
DATA_RETRY_MAX=3
DATA_RETRY_DELAY=2

# --- Execution Gate ---
ENABLE_REAL_TRADING=false
EXECUTION_MODE=paper
EXCHANGE_API_WITHDRAWAL=false
EXCHANGE_IP_WHITELIST=disabled
STOP_LOSS_REQUIRED=true
INVALID_COND_REQUIRED=true
POSITION_LIMIT_PCT=20

# --- Risk ---
MAX_POSITION_SIZE_USDT=1000
MAX_DAILY_LOSS_USDT=200
STOP_LOSS_PCT=0.05

# --- Scheduler ---
CHECK_INTERVAL_MINUTES=15

# --- 多源新闻采集 (MultiSourceNewsCollector) ---
# Tushare Pro API token (免费注册 https://tushare.pro)
TUSHARE_TOKEN=
# RSSHub 本地服务地址 (docker run -d --name rsshub -p 1200:1200 diygod/rsshub)
RSSHUB_URL=http://127.0.0.1:1200
RSSHUB_FEED_PATH=/feed/eastmoney/news/global
# 请求延时区间 (秒) 防反爬
NEWS_REQUEST_SLEEP_MIN=1
NEWS_REQUEST_SLEEP_MAX=3
